{
  "expo": {
    "name": "lezzet-ankara",
    "slug": "lezzet-ankara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16171D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ekotan.lezzetankara",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/inter/Inter_18pt-Regular.ttf",
            "./assets/fonts/inter/Inter_18pt-Medium.ttf",
            "./assets/fonts/inter/Inter_18pt-SemiBold.ttf"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "63f4ed9f-0bcc-4b5c-a04b-8af73109b050"
      }
    },
    "owner": "ekotan"
  }
}
